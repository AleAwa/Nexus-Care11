                aiMsg.innerHTML = `
                    <div class="w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center flex-shrink-0">
                        <i data-lucide="bot" class="w-4 h-4 text-white"></i>
                    </div>
                    <div class="bg-white p-3 rounded-2xl rounded-tl-none shadow-sm max-w-[80%]">
                        <div class="flex gap-1">
                            <div class="w-2 h-2 rounded-full bg-slate-400 typing-dot"></div>
                            <div class="w-2 h-2 rounded-full bg-slate-400 typing-dot"></div>
                            <div class="w-2 h-2 rounded-full bg-slate-400 typing-dot"></div>
                        </div>
                    </div>
                `;
                chat.appendChild(aiMsg);
                chat.scrollTop = chat.scrollHeight;
                lucide.createIcons();

                // Show result after delay
                setTimeout(() => {
                    aiMsg.remove();
                    
                    const responseMsg = document.createElement('div');
                    responseMsg.className = 'chat-bubble flex gap-3';
                    
                    // Determine triage level based on keywords
                    let level = 'normal-green';
                    let levelText = '普通门诊 (绿色)';
                    let desc = '建议预约消化内科门诊，非紧急情况。';
                    let confidence = '92%';
                    let showEscalate = false;

                    if (value.includes('痛') || value.includes('疼')) {
                        if (value.includes('很') || value.includes('剧烈') || value.includes('受不了')) {
                            level = 'urgent-yellow';
                            levelText = '紧急 (黄色)';
                            desc = '疼痛程度较高，建议尽快就诊，已为您优先排队。';
                            confidence = '88%';
                            showEscalate = true;
                        }
                    }
                    if (value.includes('血') || value.includes('昏迷') || value.includes('无法呼吸')) {
                        level = 'emergency-red';
                        levelText = '危急 (红色)';
                        desc = '检测到危急症状，请立即前往急诊室或拨打120！';
                        confidence = '96%';
                        showEscalate = false;
                    }

                    responseMsg.innerHTML = `
                        <div class="w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center flex-shrink-0">
                            <i data-lucide="bot" class="w-4 h-4 text-white"></i>
                        </div>
                        <div class="bg-white p-3 rounded-2xl rounded-tl-none shadow-sm max-w-[80%]">
                            <p class="text-sm text-slate-700">已收到您的描述，正在进行智能分诊评估...</p>
                        </div>
                    `;
                    chat.appendChild(responseMsg);
                    chat.scrollTop = chat.scrollHeight;
                    lucide.createIcons();

                    // Show result panel
                    setTimeout(() => {
                        result.classList.remove('hidden');
                        result.classList.add('fade-in');
                        
                        const levelEl = document.getElementById('triageLevel');
                        const descEl = document.getElementById('triageDesc');
                        const confEl = document.getElementById('confidenceScore');
                        const confBar = document.getElementById('confidenceBar');
                        const escalateBtn = document.getElementById('humanEscalateBtn');

                        levelEl.textContent = levelText;
                        levelEl.className = `font-bold text-lg ${level === 'emergency-red' ? 'text-red-600' : level === 'urgent-yellow' ? 'text-amber-600' : 'text-green-600'}`;
                        descEl.textContent = desc;
                        confEl.textContent = confidence;
                        confBar.style.width = confidence;
                        confBar.className = `confidence-bar h-2 rounded-full ${level === 'emergency-red' ? 'bg-red-500' : level === 'urgent-yellow' ? 'bg-amber-500' : 'bg-green-500'}`;
                        
                        if (showEscalate) {
                            escalateBtn.classList.remove('hidden');
                        } else {
                            escalateBtn.classList.add('hidden');
                        }

                        if (level === 'emergency-red') {
                            result.classList.add('pulse-ring');
                            result.style.borderLeftColor = '#ef4444';
                        } else if (level === 'urgent-yellow') {
                            result.style.borderLeftColor = '#f59e0b';
                        } else {
                            result.style.borderLeftColor = '#10b981';
                        }
                    }, 800);
                }, 1500);
            }, 500);
        }

        // Simulate adding medical terms to memo in real-time
        setInterval(() => {
            const memoContainer = document.getElementById('memoContainer');
            const terms = [
                { term: 'Endoscopy', def: '内镜检查 - 使用软管摄像头观察消化道内部' },
                { term: 'Biopsy', def: '活检 - 取少量组织样本进行病理检查' }
            ];
            
            // Randomly add terms if less than 4
            if (memoContainer.children.length < 4 && Math.random() > 0.7) {
                const term = terms[Math.floor(Math.random() * terms.length)];
                const div = document.createElement('div');
                div.className = 'flex items-start gap-2 text-sm chat-bubble';
                div.innerHTML = `
                    <i data-lucide="check-circle-2" class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0"></i>
                    <p class="text-slate-700"><span class="font-semibold">${term.term}:</span> ${term.def}</p>
                `;
                memoContainer.appendChild(div);
                lucide.createIcons();
            }
        }, 5000);

        // Add parallax effect to wave background
        document.addEventListener('mousemove', (e) => {
            const wave = document.querySelector('.wave-bg');
            const x = e.clientX / window.innerWidth;
            const y = e.clientY / window.innerHeight;
            wave.style.transform = `translate(${x * 20}px, ${y * 20}px)`;
        });

        // Intersection Observer for fade-in animations
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('fade-in');
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        document.querySelectorAll('.feature-card').forEach((el) => observer.observe(el));
    </script>
</body>
</html>
